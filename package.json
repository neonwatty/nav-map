{
  "name": "nav-map-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "dev:site": "pnpm --filter site dev",
    "build": "pnpm --filter @neonwatty/nav-map build && pnpm --filter demo build",
    "build:site": "pnpm --filter @neonwatty/nav-map build && pnpm --filter site build",
    "build:core": "pnpm --filter @neonwatty/nav-map build",
    "lint": "eslint packages/*/src/ packages/site/app/ packages/site/scripts/",
    "lint:fix": "eslint packages/*/src/ packages/site/app/ packages/site/scripts/ --fix",
    "test": "pnpm --filter @neonwatty/nav-map test && pnpm --filter @neonwatty/nav-map-scanner test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css}\"",
    "knip": "knip",
    "knip:production": "knip --production",
    "validate": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm knip:production && pnpm build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^5.87.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.13.1"
}
