{
  "name": "@neonwatty/nav-map-scanner",
  "version": "0.1.0",
  "description": "CLI scanner for generating nav-map.json from Next.js apps or URLs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neonwatty/nav-map",
    "directory": "packages/scanner"
  },
  "keywords": [
    "navigation",
    "scanner",
    "cli",
    "next.js",
    "sitemap",
    "playwright"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nav-map": "./bin/nav-map.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@neonwatty/nav-map": "workspace:*",
    "adm-zip": "^0.5.17",
    "commander": "^14.0.3",
    "glob": "^11.0.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
