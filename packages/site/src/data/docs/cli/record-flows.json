{
  "slug": "cli/record-flows",
  "title": "CLI: record-flows",
  "description": "Run pre-defined flow scripts from a directory and record navigation transitions with screenshots.",
  "keywords": [
    "flow scripts",
    "automated flows",
    "record-flows",
    "test navigation"
  ],
  "sections": [
    {
      "heading": "Usage",
      "content": "```bash\nnpx @neonwatty/nav-map-scanner record-flows --flows-dir <dir> --base-url <url>\n```"
    },
    {
      "heading": "Options",
      "content": "All available options for the `record-flows` command.",
      "propsTable": [
        {
          "name": "--flows-dir",
          "type": "string",
          "required": true,
          "description": "Directory containing flow scripts"
        },
        {
          "name": "--base-url",
          "type": "string",
          "required": true,
          "description": "Base URL of the running application"
        },
        {
          "name": "--storage-state",
          "type": "string",
          "required": false,
          "description": "Path to Playwright storage state for auth"
        },
        {
          "name": "--routes",
          "type": "string",
          "required": false,
          "description": "Comma-separated routes to include"
        },
        {
          "name": "--screenshot-dir",
          "type": "string",
          "required": false,
          "default": "nav-screenshots",
          "description": "Directory for screenshots"
        },
        {
          "name": "-o, --output",
          "type": "string",
          "required": false,
          "default": "nav-map.json",
          "description": "Output file path"
        },
        {
          "name": "-n, --name",
          "type": "string",
          "required": false,
          "description": "Project name for the graph"
        },
        {
          "name": "--fail-on-test-errors",
          "type": "boolean",
          "required": false,
          "description": "Exit with error code if any flow script fails"
        }
      ]
    }
  ]
}