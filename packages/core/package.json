{
  "name": "@neonwatty/nav-map",
  "version": "0.1.0",
  "description": "Interactive navigation map visualization for Next.js apps and websites",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neonwatty/nav-map",
    "directory": "packages/core"
  },
  "keywords": [
    "navigation",
    "sitemap",
    "react-flow",
    "next.js",
    "visualization",
    "graph"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.11.1",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3"
  }
}
