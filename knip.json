{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@xyflow/react", "elkjs", "html2canvas"]
    },
    "packages/scanner": {
      "entry": ["src/index.ts", "src/cli.ts", "src/reporter.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["playwright", "sharp", "ts-morph", "adm-zip", "glob"]
    },
    "packages/demo": {
      "entry": ["app/**/{layout,page}.tsx"],
      "project": ["app/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@neonwatty/nav-map"]
    },
    "packages/site": {
      "entry": ["app/**/{layout,page}.tsx", "scripts/**/*.ts"],
      "project": ["app/**/*.{ts,tsx}", "components/**/*.{ts,tsx}", "scripts/**/*.ts"],
      "ignoreDependencies": ["@neonwatty/nav-map", "tsx", "ts-morph"]
    }
  },
  "ignoreExportsUsedInFile": { "interface": true, "type": true }
}
